APP_NAME=hsportal-helper
APP_ENV=dev
LOG_LEVEL=INFO
HSPORTAL_CRAWL_INTERVAL_HOURS=1

# Alibaba Cloud Model Studio / DashScope OpenAI-compatible endpoint
QWEN_API_KEY=replace-with-your-api-key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-vl-plus
QWEN_ENABLE_THINKING=true
# Optional. Set a positive integer only when QWEN_ENABLE_THINKING=true.
QWEN_THINKING_BUDGET=2048
LLM_MAX_IMAGE_BYTES=10485760
